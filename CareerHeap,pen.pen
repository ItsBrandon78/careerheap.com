                          ]
                        },
                        {
                          "type": "text",
                          "id": "GiWFg",
                          "name": "midCtaTitle",
                          "fill": "$text-primary",
                          "content": "Check your resume for these mistakes",
                          "fontFamily": "Inter",
                          "fontSize": 16,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "Ltedc",
                          "name": "midCtaDesc",
                          "fill": "$text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Use our free Resume Analyzer to get instant, AI-powered feedback.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "id": "6rBwY",
                      "type": "ref",
                      "ref": "yV1lY",
                      "name": "ctaBtn",
                      "width": "fit_content",
                      "height": "fit_content",
                      "x": 575,
                      "y": 35.5,
                      "descendants": {
                        "O5nS5": {
                          "content": "Try Free",
                          "x": 22,
                          "y": 13
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "u2lmu",
                  "name": "bpP4",
                  "fill": "$text-primary",
                  "content": "4. Making Your Resume Too Long",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "1BvN7",
                  "name": "bpP4Body",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Unless you have 15+ years of experience, keep it to one page. Recruiters don't have time to read your life story. Focus on the most relevant and impactful experiences for the specific role you're targeting.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "z1c1h",
                  "name": "bpP5",
                  "fill": "$text-primary",
                  "content": "5. Forgetting to Proofread",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "wIs7o",
                  "name": "bpP5Body",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Typos and grammatical errors signal carelessness. Always proofread multiple times, use a tool like Grammarly, and have a friend review it. One small mistake can undermine an otherwise strong resume.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                }
              ]
            },
