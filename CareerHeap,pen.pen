            },
            {
              "type": "frame",
              "id": "KKq4n",
              "name": "heroImage",
              "metadata": {
                "type": "unsplash",
                "username": "danieledandreti",
                "link": "https://unsplash.com/@danieledandreti",
                "author": "Daniele D'Andreti"
              },
              "width": 700,
              "height": 380,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1564627488683-453be0de2aad?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzEzMTE1MjJ8&ixlib=rb-4.1.0&q=80&w=1080",
                "mode": "fill"
              },
              "cornerRadius": "$radius-lg"
            },
            {
              "type": "frame",
              "id": "wX02q",
              "name": "articleBody",
              "width": 700,
              "layout": "vertical",
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "Oe6aE",
                  "name": "bpIntro",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Your resume is the first impression you make on a hiring manager. Yet most job seekers make the same critical mistakes — ones that can send your application straight to the rejection pile before a human ever reads it.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "mr0gZ",
                  "name": "bpH2a",
                  "fill": "$text-primary",
                  "content": "1. Writing a Generic Objective Statement",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "IPTlX",
                  "name": "bpP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The days of 'seeking a challenging position' are over. Replace your objective with a targeted professional summary that speaks directly to the role you're applying for. Hiring managers spend an average of 7 seconds scanning your resume — make those seconds count.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "CJrrV",
                  "name": "bpH2b",
                  "fill": "$text-primary",
                  "content": "2. Listing Duties Instead of Achievements",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "CSdt1",
                  "name": "bpP2",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Don't tell employers what you were supposed to do — tell them what you actually accomplished. Use the formula: Action Verb + Task + Result. For example, instead of 'Managed social media accounts,' write 'Grew Instagram following by 340% in 6 months, generating $50K in attributable revenue.'",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "u0u5d",
                  "name": "bpH2c",
                  "fill": "$text-primary",
                  "content": "3. Ignoring ATS Formatting",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "uMp6T",
                  "name": "bpP3",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Most companies use Applicant Tracking Systems to filter resumes before they reach a human. Fancy layouts, graphics, and unusual fonts often get mangled by these systems. Stick to clean formatting, standard section headers, and relevant keywords from the job description.",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "DOslw",
                  "name": "Mid-Article CTA",
                  "width": "fill_container",
                  "fill": "$accent-light",
                  "cornerRadius": "$radius-lg",
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#2563EB20"
                  },
                  "gap": 20,
                  "padding": 24,
                  "alignItems": "center",
                  "children": [
                    {
